TENCENT_COS_SECRET_KEY=""
TENCENT_COS_BUCKET=""
TENCENT_COS_REGION=""
TENCENT_COS_SIGNED_URL_EXPIRES_SECONDS="600"

# Admin email notifications for payment review, refund review, and VIP adjustments.
# Set ADMIN_EMAIL_NOTIFICATIONS_ENABLED="false" to disable without code changes.
ADMIN_EMAIL_NOTIFICATIONS_ENABLED="true"
ADMIN_ALERT_EMAILS="huqingwei5942@gmail.com,hunathan@qq.com"
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="hunathan@qq.com"
SMTP_PASSWORD="your-qq-smtp-authorization-code"
SMTP_FROM="ENHE AI <hunathan@qq.com>"
# User-facing actions wait briefly for critical admin email delivery, then continue to avoid stuck forms.
ADMIN_EMAIL_ACTION_WAIT_MS="1500"

