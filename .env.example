AUTH_COOKIE_NAME="enhe_session"
CSRF_COOKIE_NAME="enhe_csrf"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UPLOAD_DIR="./public/uploads"
UPLOAD_ALLOWED_EXTENSIONS=".zip,.rar,.7z,.exe,.msi,.dmg,.pkg,.pdf,.png,.jpg,.jpeg,.webp,.gif,.txt,.csv,.xlsx,.docx,.pptx"
DOWNLOAD_RATE_LIMIT_MAX="10"
DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS="60"
